{
  "info": {
    "name": "Inventory System API Tests",
    "description": "API testing for the Inventory System.\n\nAuthentication is handled automatically: a collection-level pre-request script calls POST /api/auth/token to get a JWT, then attaches it as a Bearer header to every request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// ──────────────────────────────────────────────────────────",
          "// Collection-level pre-request: auto-authenticate via Keycloak",
          "// ──────────────────────────────────────────────────────────",
          "const baseUrl  = pm.collectionVariables.get('baseUrl');",
          "const username = pm.collectionVariables.get('authUsername');",
          "const password = pm.collectionVariables.get('authPassword');",
          "",
          "const cachedToken = pm.collectionVariables.get('accessToken');",
          "const tokenExpiry = pm.collectionVariables.get('tokenExpiry');",
          "",
          "// Helper to inject the Authorization header into the outgoing request",
          "function setAuthHeader(token) {",
          "    if (token) {",
          "        pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "    }",
          "}",
          "",
          "// Reuse the cached token if it hasn't expired yet",
          "if (cachedToken && tokenExpiry && Date.now() < parseInt(tokenExpiry) - 10000) {",
          "    setAuthHeader(cachedToken);",
          "    return;",
          "}",
          "",
          "// Obtain a new token asynchronously",
          "pm.sendRequest({",
          "    url: baseUrl + '/api/auth/token',",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/json' },",
          "    body: {",
          "        mode: 'raw',",
          "        raw: JSON.stringify({ username: username, password: password })",
          "    }",
          "}, function (err, res) {",
          "    if (err || !res || res.code !== 200) {",
          "        console.error('Auth request failed:', err || res.text());",
          "        return;",
          "    }",
          "    var json = res.json();",
          "    var token = json.access_token;",
          "    pm.collectionVariables.set('accessToken', token);",
          "    var expiresInMs = (json.expires_in || 300) * 1000;",
          "    pm.collectionVariables.set('tokenExpiry', String(Date.now() + expiresInMs));",
          "    setAuthHeader(token);",
          "    console.log('Authenticated as ' + username);",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "GET All Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ── Status Code Validation ──",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ── Content-Type / Contract Validation ──",
              "pm.test('Response Content-Type is application/json', function () {",
              "    pm.response.to.have.header('Content-Type');",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "// ── Payload Structure Validation ──",
              "pm.test('Response contains items array (paged response)', function () {",
              "    var jsonData = pm.response.json();",
              "    var items = Array.isArray(jsonData) ? jsonData : jsonData.items;",
              "    pm.expect(items).to.be.an('array');",
              "});",
              "",
              "pm.test('Each product has required fields (id, name, codeSKU, price, quantity)', function () {",
              "    var jsonData = pm.response.json();",
              "    var items = Array.isArray(jsonData) ? jsonData : jsonData.items;",
              "    if (items.length === 0) { return; }",
              "    items.forEach(function (product) {",
              "        pm.expect(product).to.have.property('id');",
              "        pm.expect(product).to.have.property('name');",
              "        pm.expect(product).to.have.property('codeSKU');",
              "        pm.expect(product).to.have.property('price');",
              "        pm.expect(product).to.have.property('quantity');",
              "    });",
              "});",
              "",
              "pm.test('Product prices are non-negative numbers', function () {",
              "    var jsonData = pm.response.json();",
              "    var items = Array.isArray(jsonData) ? jsonData : jsonData.items;",
              "    if (items.length === 0) { return; }",
              "    items.forEach(function (product) {",
              "        pm.expect(product.price).to.be.a('number');",
              "        pm.expect(product.price).to.be.at.least(0);",
              "    });",
              "});",
              "",
              "pm.test('Response time is under 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/product",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "product"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8090",
      "type": "string"
    },
    {
      "key": "authUsername",
      "value": "api-test",
      "type": "string"
    },
    {
      "key": "authPassword",
      "value": "12345",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tokenExpiry",
      "value": "",
      "type": "string"
    }
  ]
}
