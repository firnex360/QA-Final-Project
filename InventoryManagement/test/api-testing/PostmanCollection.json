{
  "info": {
    "name": "Inventory System API Tests",
    "description": "Black-Box API testing for the Inventory System ProductController.\nAuthentication is handled automatically via a collection-level pre-request script that obtains a JWT from the /api/auth/token endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// ──────────────────────────────────────────────────────────",
          "// Collection-level pre-request: auto-authenticate with Keycloak",
          "// ──────────────────────────────────────────────────────────",
          "const baseUrl = pm.collectionVariables.get('baseUrl');",
          "const username = pm.collectionVariables.get('authUsername');",
          "const password = pm.collectionVariables.get('authPassword');",
          "",
          "// Reuse the token if it hasn't expired yet (with a 10s buffer)",
          "const tokenExpiry = pm.collectionVariables.get('tokenExpiry');",
          "if (tokenExpiry && Date.now() < parseInt(tokenExpiry) - 10000) {",
          "    return;",
          "}",
          "",
          "pm.sendRequest({",
          "    url: baseUrl + '/api/auth/token',",
          "    method: 'POST',",
          "    header: { 'Content-Type': 'application/json' },",
          "    body: {",
          "        mode: 'raw',",
          "        raw: JSON.stringify({ username: username, password: password })",
          "    }",
          "}, function (err, res) {",
          "    if (err) {",
          "        console.error('Auth pre-request failed:', err);",
          "        return;",
          "    }",
          "    if (res.code !== 200) {",
          "        console.error('Auth returned ' + res.code + ':', res.text());",
          "        return;",
          "    }",
          "    var json = res.json();",
          "    pm.collectionVariables.set('accessToken', json.access_token);",
          "    // Cache the expiry time so we don't re-auth on every single request",
          "    var expiresInMs = (json.expires_in || 300) * 1000;",
          "    pm.collectionVariables.set('tokenExpiry', String(Date.now() + expiresInMs));",
          "    console.log('Authenticated as ' + username + ' — token valid for ' + json.expires_in + 's');",
          "});"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "GET All Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response payload contains a valid JSON array of items\", function () {",
              "    var jsonData = pm.response.json();",
              "    // The API returns a PagedResponse object, so we check if 'items' is an array",
              "    var isArray = Array.isArray(jsonData) || (jsonData.items && Array.isArray(jsonData.items));",
              "    pm.expect(isArray).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/product",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "product"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST Create Product (Valid Data)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test(\"Response contains a product ID\", function () {",
              "    var jsonData = pm.response.json();",
              "    var id = jsonData.productId || jsonData.id;",
              "    pm.expect(id).to.exist;",
              "    ",
              "    // Save the ID for subsequent tests",
              "    pm.collectionVariables.set(\"createdProductId\", id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Postman Test Product\",\n  \"codeSKU\": \"PM-TEST-001\",\n  \"description\": \"A product created via Postman tests.\",\n  \"category\": \"Testing\",\n  \"price\": 19.99,\n  \"quantity\": 100,\n  \"minimumStockLevel\": 10,\n  \"isActive\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/product",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "product"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET Product By ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Payload contains the correct name and sku\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql(\"Postman Test Product\");",
              "    pm.expect(jsonData.codeSKU).to.eql(\"PM-TEST-001\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/product/{{createdProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "product",
            "{{createdProductId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST Create Product (Invalid Data - Negative Price)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 400 Bad Request\", function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Invalid Product\",\n  \"codeSKU\": \"INV-001\",\n  \"description\": \"Product with negative price.\",\n  \"category\": \"Testing\",\n  \"price\": -5.00,\n  \"quantity\": 10,\n  \"minimumStockLevel\": 5,\n  \"isActive\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/product",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "product"
          ]
        }
      },
      "response": []
    },
    {
      "name": "DELETE Product (Cleanup)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Deletion message confirms success\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.include(\"deleted successfully\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/product/{{createdProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "product",
            "{{createdProductId}}"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8090",
      "type": "string"
    },
    {
      "key": "authUsername",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "authPassword",
      "value": "admin123",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tokenExpiry",
      "value": "",
      "type": "string"
    },
    {
      "key": "createdProductId",
      "value": "",
      "type": "string"
    }
  ]
}
