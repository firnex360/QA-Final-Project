@page "/read"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject PermissionStore Permissions

<PageTitle>Read</PageTitle>

<div class="page-header">
    <div>
        <h1 class="mb-1">Products</h1>
        <p role="status" class="text-muted mb-0">Browse, filter, and manage the current inventory.</p>
    </div>
    @if (canManageProducts)
    {
        <NavLink class="btn btn-primary" href="create">+ Create Product</NavLink>
    }
</div>

<div class="filter-bar">
    <div class="filter-search">
        <span class="filter-search-icon">🔍</span>
        <input class="form-control" type="search" placeholder="Search by name, SKU, or description..."
               value="@searchTerm" @oninput="OnSearchInput" aria-label="Search products" />
    </div>

    <!-- Low stock filter chip -->
    <button class="btn filter-chip @(lowStockOnly ? "is-on" : "")" @onclick="ToggleLowStock"
            title="Show only products at or below their minimum stock level">
        ⚠️ Low stock@(lowStockCount > 0 ? $" ({lowStockCount})" : "")
    </button>

    <!-- Category filter -->
    <div class="filter-menu-wrap">
        <button class="btn filter-icon-btn @(HasCategoryFilter ? "is-active" : "")"
                @onclick="ToggleCategoryMenu" title="Filter by category" aria-label="Filter by category">
            🏷️
            @if (HasCategoryFilter)
            {
                <span class="filter-dot"></span>
            }
        </button>
        @if (showCategoryMenu)
        {
            <div class="filter-popup">
                <div class="filter-popup-title">Category</div>
                <button class="filter-popup-item @(selectedCategory == "" ? "selected" : "")"
                        @onclick='() => SelectCategory("")'>All categories</button>
                @foreach (var category in categories)
                {
                    <button class="filter-popup-item @(selectedCategory == category ? "selected" : "")"
                            @onclick="() => SelectCategory(category)">@category</button>
                }
            </div>
        }
    </div>

    <!-- Sort -->
    <div class="filter-menu-wrap">
        <button class="btn filter-icon-btn @(HasCustomSort ? "is-active" : "")"
                @onclick="ToggleSortMenu" title="Sort" aria-label="Sort">
            ↕️
            @if (HasCustomSort)
            {
                <span class="filter-dot"></span>
            }
        </button>
        @if (showSortMenu)
        {
            <div class="filter-popup">
                <div class="filter-popup-title">Sort by</div>
                @foreach (var opt in sortOptions)
                {
                    <button class="filter-popup-item @(sortBy == opt.Key ? "selected" : "")"
                            @onclick="() => SelectSort(opt.Key)">@opt.Value</button>
                }
                <div class="filter-popup-divider"></div>
                <div class="filter-popup-title">Direction</div>
                <button class="filter-popup-item @(!sortDescending ? "selected" : "")"
                        @onclick="() => SelectSortDirection(false)">↑ Ascending</button>
                <button class="filter-popup-item @(sortDescending ? "selected" : "")"
                        @onclick="() => SelectSortDirection(true)">↓ Descending</button>
            </div>
        }
    </div>

    @if (HasActiveFilters)
    {
        <button class="btn btn-link btn-sm filter-clear" @onclick="ClearFilters">Clear</button>
    }
</div>

@if (showCategoryMenu || showSortMenu)
{
    <div class="filter-backdrop" @onclick="CloseMenus"></div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (products == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <p class="text-muted small mb-2">@totalCount product@(totalCount == 1 ? "" : "s") found</p>

    @if (products.Count == 0)
    {
        <div class="empty-state">
            No products match your filters.
            <button class="btn btn-link btn-sm p-0 align-baseline" @onclick="ClearFilters">Clear filters</button>
        </div>
    }

    <div class="product-grid">
        @foreach (var product in products)
        {
            <div class="product-card @StockStateClass(product)">
                <div class="product-card-head">
                    <div class="product-name" title="@product.Name">@product.Name</div>
                    <span class="stock-badge @StockStateClass(product)">@StockStateLabel(product)</span>
                </div>

                <div class="product-meta">
                    <span class="badge text-bg-light border">@product.CodeSKU</span>
                    <span class="product-category">@product.Category</span>
                    @if (!product.IsActive)
                    {
                        <span class="badge text-bg-secondary">Inactive</span>
                    }
                </div>

                <p class="product-desc" title="@product.Description">@product.Description</p>

                <div class="product-stock-row">
                    <div class="product-price">@product.Price.ToString("C")</div>
                    <div class="product-qty" title="Minimum stock level: @product.MinimumStockLevel">
                        <span class="qty-number">@product.Quantity</span>
                        <span class="qty-min">/ min @product.MinimumStockLevel</span>
                    </div>
                </div>

                <!-- Actions render only for the scopes Keycloak grants this user -->
                <div class="stock-actions">
                    @if (canManageStock)
                    {
                        <button class="btn stock-btn stock-out" title="Stock out"
                                @onclick="() => OpenAdjust(product, stockIn: false)">−</button>
                        <button class="btn stock-btn stock-in" title="Stock in"
                                @onclick="() => OpenAdjust(product, stockIn: true)">+</button>
                    }
                    @if (canManageProducts)
                    {
                        <div class="card-actions">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => EditProduct(product)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(product)">Delete</button>
                        </div>
                    }
                </div>

                @if (adjustProductId == product.Id)
                {
                    <div class="stock-adjust-panel">
                        <div class="stock-adjust-title">
                            @(adjustIsStockIn ? "📦 Stock in" : "📤 Stock out") — how many?
                        </div>
                        <div class="stock-adjust-controls">
                            <input class="form-control form-control-sm stock-adjust-amount" type="number" min="1"
                                   @bind="adjustAmount" aria-label="Amount" />
                        </div>
                        <div class="stock-adjust-buttons">
                            <button class="btn btn-sm @(adjustIsStockIn ? "btn-success" : "btn-warning")"
                                    disabled="@adjustBusy" @onclick="ConfirmAdjust">
                                @(adjustBusy ? "Saving..." : adjustIsStockIn ? $"Add {adjustAmount}" : $"Remove {adjustAmount}")
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CloseAdjust">Cancel</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="pager-bar">
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == 1)" @onclick="PrevPage">‹ Previous</button>
        <span class="page-info">Page @currentPage of @totalPages</span>
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == totalPages)" @onclick="NextPage">Next ›</button>
    </div>
}

@if (!string.IsNullOrEmpty(toastMessage))
{
    <div class="stock-toast" role="status">@toastMessage</div>
}

@code {

    private List<Product>? products;
    private string errorMessage = string.Empty;

    private const int pageSize = 8;
    private int currentPage = 1;
    private int totalPages = 1;
    private int totalCount = 0;
    private int lowStockCount = 0;

    // Filter/sort state — mirrors the server's ProductQueryParameters.
    private string searchTerm = string.Empty;
    private string selectedCategory = string.Empty;
    private string sortBy = "name";
    private bool sortDescending = false;
    private bool lowStockOnly = false;
    private List<string> categories = new();

    // Popover open/closed state.
    private bool showCategoryMenu = false;
    private bool showSortMenu = false;

    // Quick stock adjustment state (one panel open at a time).
    private int? adjustProductId = null;
    private bool adjustIsStockIn = true;
    private int adjustAmount = 1;
    private bool adjustBusy = false;

    // Post-movement toast ("Widget: 12 → 15").
    private string toastMessage = string.Empty;
    private CancellationTokenSource? toastTimer;

    // Sort options, keyed by the value the server expects.
    private readonly Dictionary<string, string> sortOptions = new()
    {
        ["name"] = "Name",
        ["price"] = "Price",
        ["quantity"] = "Quantity",
        ["category"] = "Category",
        ["codesku"] = "SKU",
    };

    private CancellationTokenSource? searchDebounce;

    private bool HasCategoryFilter => !string.IsNullOrEmpty(selectedCategory);
    private bool HasCustomSort => sortBy != "name" || sortDescending;
    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(searchTerm) || HasCategoryFilter || HasCustomSort || lowStockOnly;

    // ── Stock state helpers ─────────────────────────────────────────
    private static string StockStateClass(Product p) =>
        p.Quantity == 0 ? "stock-state-out"
        : p.Quantity <= p.MinimumStockLevel ? "stock-state-low"
        : "stock-state-ok";

    private static string StockStateLabel(Product p) =>
        p.Quantity == 0 ? "Out of stock"
        : p.Quantity <= p.MinimumStockLevel ? "Low stock"
        : "In stock";

    // ── Quick stock adjustment ──────────────────────────────────────
    private void OpenAdjust(Product product, bool stockIn)
    {
        adjustProductId = product.Id;
        adjustIsStockIn = stockIn;
        adjustAmount = 1;
        CloseMenus();
    }

    private void CloseAdjust()
    {
        adjustProductId = null;
        adjustBusy = false;
    }

    private async Task ConfirmAdjust()
    {
        if (adjustProductId is not int id || adjustAmount < 1)
            return;

        var product = products?.FirstOrDefault(p => p.Id == id);
        if (product is null)
            return;

        adjustBusy = true;
        var delta = adjustIsStockIn ? adjustAmount : -adjustAmount;
        var previousQuantity = product.Quantity;

        try
        {
            var response = await Http.PatchAsync($"api/product/{id}/stock?delta={delta}", null);

            if (response.IsSuccessStatusCode)
            {
                var updated = await response.Content.ReadFromJsonAsync<Product>();
                if (updated is not null)
                    product.Quantity = updated.Quantity;

                await ShowToast($"{product.Name}: {previousQuantity} → {product.Quantity}" +
                                (adjustIsStockIn ? "  📦 in" : "  📤 out"));
                CloseAdjust();
                await RefreshStatsAsync(); // keep the low-stock chip count current

                // If we're filtering by low stock, the product may have left the filter — reload.
                if (lowStockOnly)
                    await LoadProductsAsync(currentPage);
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                adjustBusy = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Stock update failed: {ex.Message}";
            adjustBusy = false;
        }
    }

    private async Task ShowToast(string message)
    {
        toastMessage = message;
        toastTimer?.Cancel();
        toastTimer = new CancellationTokenSource();
        var token = toastTimer.Token;
        try
        {
            await Task.Delay(3500, token);
            toastMessage = string.Empty;
            StateHasChanged();
        }
        catch (TaskCanceledException) { /* replaced by a newer toast */ }
    }

    // ── Paging ──────────────────────────────────────────────────────
    private async Task PrevPage()
    {
        if (currentPage > 1)
            await LoadProductsAsync(currentPage - 1);
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
            await LoadProductsAsync(currentPage + 1);
    }

    // ── Filters ─────────────────────────────────────────────────────
    // Debounce typing so we only hit the API after the user pauses (400 ms),
    // instead of firing one request per keystroke.
    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;

        searchDebounce?.Cancel();
        searchDebounce = new CancellationTokenSource();
        var token = searchDebounce.Token;

        try
        {
            await Task.Delay(400, token);
            await LoadProductsAsync(1); // new search always starts at page 1
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // superseded by a newer keystroke — do nothing
        }
    }

    private async Task ToggleLowStock()
    {
        lowStockOnly = !lowStockOnly;
        await LoadProductsAsync(1);
    }

    // Only one popover open at a time; clicking the same button toggles it closed.
    private void ToggleCategoryMenu()
    {
        showCategoryMenu = !showCategoryMenu;
        showSortMenu = false;
    }

    private void ToggleSortMenu()
    {
        showSortMenu = !showSortMenu;
        showCategoryMenu = false;
    }

    private void CloseMenus()
    {
        showCategoryMenu = false;
        showSortMenu = false;
    }

    private async Task SelectCategory(string category)
    {
        selectedCategory = category;
        CloseMenus();
        await LoadProductsAsync(1);
    }

    private async Task SelectSort(string key)
    {
        sortBy = key;
        showSortMenu = false;
        await LoadProductsAsync(1);
    }

    private async Task SelectSortDirection(bool descending)
    {
        sortDescending = descending;
        showSortMenu = false;
        await LoadProductsAsync(1);
    }

    private async Task ClearFilters()
    {
        searchTerm = string.Empty;
        selectedCategory = string.Empty;
        sortBy = "name";
        sortDescending = false;
        lowStockOnly = false;
        CloseMenus();
        await LoadProductsAsync(1);
    }

    // ── Data loading ────────────────────────────────────────────────
    // Builds the query string the server's ProductQueryParameters binds from.
    // Only non-default values are included, keeping URLs clean.
    private string BuildQuery(int page)
    {
        var query = $"api/product?pageNumber={page}&pageSize={pageSize}";

        if (!string.IsNullOrWhiteSpace(searchTerm))
            query += $"&searchTerm={Uri.EscapeDataString(searchTerm)}";
        if (!string.IsNullOrEmpty(selectedCategory))
            query += $"&category={Uri.EscapeDataString(selectedCategory)}";
        if (sortBy != "name")
            query += $"&sortBy={sortBy}";
        if (sortDescending)
            query += "&sortDescending=true";
        if (lowStockOnly)
            query += "&lowStockOnly=true";

        return query;
    }

    // Fetches a single page from the server, which handles the paging/filtering/sorting.
    private async Task LoadProductsAsync(int page)
    {
        try
        {
            var response = await Http.GetFromJsonAsync<PagedResponse<Product>>(BuildQuery(page));

            products = response?.Items ?? new List<Product>();
            totalPages = response?.TotalPages ?? 1;
            currentPage = response?.CurrentPage ?? 1;
            totalCount = response?.TotalCount ?? 0;
            errorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading products: {ex.Message}";
            products = new List<Product>(); // show empty grid instead of infinite spinner
            Console.Error.WriteLine(ex.Message);
        }
    }

    // Reuses the existing stats endpoint — gives us the category list for the
    // filter dropdown AND the live low-stock count for the chip.
    private async Task RefreshStatsAsync()
    {
        try
        {
            var stats = await Http.GetFromJsonAsync<ProductStatsDto>("api/product/stats");
            categories = stats?.ByCategory.Select(c => c.Label).OrderBy(c => c).ToList() ?? new();
            lowStockCount = stats?.LowStockCount ?? 0;
        }
        catch
        {
            categories = new(); // chip/dropdown just degrade gracefully if stats are unavailable
        }
    }

    // What the user may do comes from Keycloak (via /api/permissions/me), not from
    // anything declared in this project. Presentation only — the API enforces the same
    // policies, so hiding a button is convenience, not security.
    private bool canManageProducts => Permissions.Has("Products", "manage");
    private bool canManageStock => Permissions.Has("ProductStock", "manage");

    protected override async Task OnInitializedAsync()
    {
        await Permissions.EnsureLoadedAsync();

        // Load the first page and the stats in parallel — independent requests.
        await Task.WhenAll(LoadProductsAsync(currentPage), RefreshStatsAsync());
    }

    private void EditProduct(Product product)
    {
        NavigationManager.NavigateTo($"/edit/{product.Id}");
    }

    private async Task DeleteProduct(Product product)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{product.Name}'??? This cannot be undone, pal.");
        if (!confirmed)
            return;

        try
        {
            var response = await Http.DeleteAsync($"api/product/{product.Id}");

            if (response.IsSuccessStatusCode)
            {
                // Reload from the server so page counts stay in sync. The server clamps
                // the page number, so deleting the last item on the last page falls back safely.
                await LoadProductsAsync(currentPage);
                await RefreshStatsAsync();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Delete failed: {response.StatusCode} — {errorContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
    }
}
