@page "/read"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Read</PageTitle>

<div class="page-header">
    <div>
        <h1 class="mb-1">Read Products</h1>
        <p role="status" class="text-muted mb-0">Browse and manage the current inventory.</p>
    </div>
    <NavLink class="btn btn-primary" href="create">+ Create Product</NavLink>
</div>

@if (products == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="table-card">
        <div class="table-responsive">
            <table class="table data-table align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Code SKU</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Quantity</th>
                        <th class="text-end">Min. Stock</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in products)
                    {
                        <tr>
                            <td class="fw-semibold">@product.Name</td>
                            <td><span class="badge text-bg-light border">@product.CodeSKU</span></td>
                            <td>@product.Description</td>
                            <td>@product.Category</td>
                            <td class="text-end">@product.Price.ToString("C")</td>
                            <td class="text-end">@product.Quantity</td>
                            <td class="text-end">@product.MinimumStockLevel</td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="badge text-bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditProduct(product)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(product)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

    <div class="pager-bar">
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == 1)" @onclick="PrevPage">‹ Previous</button>
        <span class="page-info">Page @currentPage of @totalPages</span>
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == totalPages)" @onclick="NextPage">Next ›</button>
    </div>
}

@code {

    private List<Product>? products;
    private string errorMessage = string.Empty;

    private const int pageSize = 5;
    private int currentPage = 1;
    private int totalPages = 1;

    private async Task PrevPage()
    {
        if (currentPage > 1)
            await LoadProductsAsync(currentPage - 1);
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
            await LoadProductsAsync(currentPage + 1);
    }

    // Fetches a single page from the server, which handles the paging/filtering/sorting.
    private async Task LoadProductsAsync(int page)
    {
        try
        {
            var response = await Http.GetFromJsonAsync<PagedResponse<Product>>(
                $"api/product?pageNumber={page}&pageSize={pageSize}");

            products = response?.Items ?? new List<Product>();
            totalPages = response?.TotalPages ?? 1;
            currentPage = response?.CurrentPage ?? 1;
            errorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading products: {ex.Message}";
            products = new List<Product>(); // show empty table instead of infinite spinner
            Console.Error.WriteLine(ex.Message);
        }
    }

    private bool isAdmin;
    private bool isStaff;
    private bool isManager;
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isAdmin = user.IsInRole("adminY");
        isStaff = user.IsInRole("staffY");
        isManager = user.IsInRole("managerY");

        await LoadProductsAsync(currentPage);
    }

    private void EditProduct(Product product)
    {
        NavigationManager.NavigateTo($"/edit/{product.Id}");
    }
    private async Task DeleteProduct(Product product)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{product.Name}'??? This cannot be undone, pal.");
        if (!confirmed)
            return;

        try
        {
            var response = await Http.DeleteAsync($"api/product/{product.Id}");

            if (response.IsSuccessStatusCode)
            {
                // Reload from the server so page counts stay in sync. The server clamps
                // the page number, so deleting the last item on the last page falls back safely.
                await LoadProductsAsync(currentPage);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Delete failed: {response.StatusCode} — {errorContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
    }
}