@page "/read"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Read</PageTitle>

<h1>Read Products</h1>

<p role="status">Read the information from the current thinga-ma-gig</p>

<NavLink class="nav-link" href="create">
    <button class="btn btn-primary">Create Product</button>
</NavLink>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-2" role="alert">@errorMessage</div>
}

@if (products == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Code SKU</th>
                <th>Description</th>
                <th>Category</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Min. Stock</th>
                <th>[A]</th>
                <th>Edit</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in PagedProducts)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.CodeSKU</td>
                    <td>@product.Description</td>
                    <td>@product.Category</td>
                    <td>@product.Price</td>
                    <td>@product.Quantity</td>
                    <td>@product.MinimumStockLevel</td>
                    <td>@product.IsActive</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditProduct(product)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(product)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav class="d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == 1)" @onclick="PrevPage">Previous</button>
        <span>Page @currentPage of @TotalPages</span>
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == TotalPages)" @onclick="NextPage">Next</button>
    </nav>
}

@code {

    private List<Product>? products;
    private string errorMessage = string.Empty;

    private const int pageSize = 5;
    private int currentPage = 1;
    private int TotalPages => products is null || products.Count == 0 ? 1 : (int)Math.Ceiling(products.Count / (double)pageSize);
    private IEnumerable<Product> PagedProducts =>
        products is null ? Enumerable.Empty<Product>() : products.Skip((currentPage - 1) * pageSize).Take(pageSize);
    private void PrevPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }

    private bool isAdmin;
    private bool isStaff;
    private bool isManager;
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        isAdmin = user.IsInRole("adminY");
        isStaff = user.IsInRole("staffY");
        isManager = user.IsInRole("managerY");

        try
        {
            products = await Http.GetFromJsonAsync<List<Product>>("api/product");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading products: {ex.Message}";
            products = new List<Product>(); // show empty table instead of infinite spinner
            Console.Error.WriteLine(ex.Message);
        }
    }

    private void EditProduct(Product product)
    {
        NavigationManager.NavigateTo($"/edit/{product.Id}");
    }
    private async Task DeleteProduct(Product product)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete '{product.Name}'??? This cannot be undone, pal.");
        if (!confirmed)
            return;

        try
        {
            var response = await Http.DeleteAsync($"api/product/{product.Id}");

            if (response.IsSuccessStatusCode)
            {
                products?.Remove(product);
                if (currentPage > TotalPages) currentPage = TotalPages;
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Delete failed: {response.StatusCode} — {errorContent}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
    }
}