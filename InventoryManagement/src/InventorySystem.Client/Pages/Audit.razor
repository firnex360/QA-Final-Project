@page "/audit"
@attribute [Authorize]
@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Audit Log</PageTitle>

<div class="page-header">
    <div>
        <h1 class="mb-1">Audit Logs</h1>
        <p class="text-muted mb-0">Review recent changes made by users.</p>
    </div>
</div>

@if (stats is not null)
{
    <div class="kpi-grid">
        <div class="kpi-card kpi-blue">
            <div class="kpi-label">Total Events</div>
            <div class="kpi-value">@stats.TotalEvents</div>
        </div>
        <div class="kpi-card kpi-green">
            <div class="kpi-label">Today</div>
            <div class="kpi-value">@stats.EventsToday</div>
        </div>
        <div class="kpi-card kpi-purple">
            <div class="kpi-label">Last 7 Days</div>
            <div class="kpi-value">@stats.EventsThisWeek</div>
        </div>
    </div>

    <div class="chart-grid">
        @if (stats.ByAction.Count > 0)
        {
            <div class="chart-card">
                <ApexChart TItem="LabelCountDto" Title="Events by Action" Height="240">
                    <ApexPointSeries TItem="LabelCountDto"
                                     Items="stats.ByAction"
                                     Name="Events"
                                     SeriesType="SeriesType.Donut"
                                     XValue="@(e => e.Label)"
                                     YAggregate="@(e => e.Sum(i => (decimal)i.Count))" />
                </ApexChart>
            </div>
        }
        @if (stats.ByDay.Count > 0)
        {
            <div class="chart-card">
                <ApexChart TItem="LabelCountDto" Title="Activity (last 7 days)" Height="240">
                    <ApexPointSeries TItem="LabelCountDto"
                                     Items="stats.ByDay"
                                     Name="Events"
                                     SeriesType="SeriesType.Line"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => (decimal)e.Count)" />
                </ApexChart>
            </div>
        }
        @if (stats.ByUser.Count > 0)
        {
            <div class="chart-card">
                <ApexChart TItem="LabelCountDto" Title="Top Users" Height="240">
                    <ApexPointSeries TItem="LabelCountDto"
                                     Items="stats.ByUser"
                                     Name="Events"
                                     SeriesType="SeriesType.Bar"
                                     XValue="@(e => e.Label)"
                                     YValue="@(e => (decimal)e.Count)" />
                </ApexChart>
            </div>
        }
    </div>
}

@if (logs is null)
{
    <p><em>Loading...</em></p>
}
else if (logs.Count == 0)
{
    <p class="text-muted">No audit records yet! :)</p>
}
else
{
    <div class="table-card">
        <div class="table-responsive">
            <table class="table data-table align-middle">
                <thead>
                    <tr>
                        <th>When (UTC)</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Changes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in PagedLogs)
                    {
                        <tr>
                            <td class="text-nowrap text-muted">@log.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@log.UserId</td>
                            <td><span class="badge @BadgeClass(log.Action)">@log.Action</span></td>
                            <td><span class="fw-semibold">@log.EntityName</span> <span class="text-muted">#@log.EntityId</span></td>
                            <td class="changes-cell">
                                <div class="audit-pills">
                                    @foreach (var change in GetChanges(log))
                                    {
                                        <span class="audit-pill @PillClass(log.Action)" title="@PillTooltip(change)">
                                            <span class="pill-field">@change.Field</span>
                                            @if (change.OldValue is not null)
                                            {
                                                <span class="pill-old">@Truncate(change.OldValue)</span>
                                                <span class="pill-arrow">→</span>
                                            }
                                            <span class="pill-value">@Truncate(change.NewValue)</span>
                                        </span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="pager-bar">
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == 1)" @onclick="PrevPage">‹ Previous</button>
        <span class="page-info">Page @currentPage of @TotalPages</span>
        <button class="btn btn-sm btn-outline-secondary" disabled="@(currentPage == TotalPages)" @onclick="NextPage">Next ›</button>
    </div>
}

@code {
    private List<AuditLogDto>? logs;
    private AuditStatsDto? stats;
    private const int pageSize = 5;
    private int currentPage = 1;
    private int TotalPages => logs is null || logs.Count == 0 ? 1 : (int)Math.Ceiling(logs.Count / (double)pageSize);
    private IEnumerable<AuditLogDto> PagedLogs =>
        logs is null ? Enumerable.Empty<AuditLogDto>() : logs.Skip((currentPage - 1) * pageSize).Take(pageSize);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            logs = await Http.GetFromJsonAsync<List<AuditLogDto>>("api/audit");
            stats = await Http.GetFromJsonAsync<AuditStatsDto>("api/audit/stats");
        }
        catch (Exception ex) { logs ??= new(); Console.Error.WriteLine(ex.Message); }
    }

    private void PrevPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }

    private static string BadgeClass(string action) => action switch
    {
        "Insert" => "text-bg-success",
        "Update" => "text-bg-primary",
        "Delete" => "text-bg-danger",
        _ => "text-bg-secondary"
    };

    private record ChangeRow(string Field, string? OldValue, string NewValue);

    // turns the raw OldValues/NewValues JSON into "Field: old → new" pills.
    private static List<ChangeRow> GetChanges(AuditLogDto log)
    {
        var oldVals = ParseJson(log.OldValues);
        var newVals = ParseJson(log.NewValues);

        return log.Action switch
        {
            "Update" => newVals
                .Select(kv => new ChangeRow(kv.Key, oldVals.GetValueOrDefault(kv.Key, "—"), kv.Value))
                .ToList(),
            "Insert" => AllRows(newVals),
            "Delete" => AllRows(oldVals),
            _ => new List<ChangeRow>()
        };
    }

    // every field as its own pill, most meaningful first.
    private static List<ChangeRow> AllRows(Dictionary<string, string> values)
    {
        string[] preferredOrder = ["Name", "CodeSKU", "Category", "Price", "Quantity", "MinimumStockLevel"];

        return values
            .Where(kv => kv.Key != "Id")
            .OrderBy(kv => { var i = Array.IndexOf(preferredOrder, kv.Key); return i < 0 ? int.MaxValue : i; })
            .Select(kv => new ChangeRow(kv.Key, null, kv.Value))
            .ToList();
    }

    // long values are cut at 30 chars so pills stay compact.
    private static string Truncate(string? value, int max = 30) =>
        string.IsNullOrEmpty(value) || value.Length <= max ? value ?? "" : value[..max] + "…";

    private static string PillTooltip(ChangeRow change) =>
        change.OldValue is null
            ? $"{change.Field}: {change.NewValue}"
            : $"{change.Field}: {change.OldValue} → {change.NewValue}";

    private static string PillClass(string action) => action switch
    {
        "Insert" => "pill-insert",
        "Delete" => "pill-delete",
        _ => "pill-update"
    };

    private static Dictionary<string, string> ParseJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new();
        try
        {
            var parsed = System.Text.Json.JsonSerializer
                .Deserialize<Dictionary<string, System.Text.Json.JsonElement>>(json);
            return parsed?.ToDictionary(
                kv => kv.Key,
                kv => kv.Value.ValueKind == System.Text.Json.JsonValueKind.Null ? "—" : kv.Value.ToString()
            ) ?? new();
        }
        catch
        {
            return new(); // malformed JSON — just render nothing rather than crash the page
        }
    }
}