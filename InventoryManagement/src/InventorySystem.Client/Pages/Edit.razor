@page "/edit/{id:int}"
@attribute [Authorize(Policy = "product:manage")]
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Edit Product</PageTitle>

<h1>Edit Product</h1>
<p role="status">Update the selected product information.</p>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else if (editingProduct == null)
{
    <div class="alert alert-danger">
        Product not found.
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(validationError))
    {
        <div class="alert alert-danger" role="alert">
            @validationError
        </div>
    }
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success" role="alert">
            @successMessage
        </div>
    }


    <form class="wrapper">

        <div class="form-group">
            <label>Name</label>
            <input @bind="editingProduct.Name"
                   class="form-control"
                   type="text" />
        </div>

        <div class="form-group">
            <label>SKU Code</label>
            <input @bind="editingProduct.CodeSKU"
                   class="form-control"
                   type="text" />
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea @bind="editingProduct.Description"
                      class="form-control">
            </textarea>
        </div>

        <div class="form-group">
            <label>Category</label>
            <select @bind="editingProduct.Category"
                    class="form-control">

                <option value="">Select category...</option>
                <option value="Electronics">Electronics</option>
                <option value="Clothing">Clothing</option>
                <option value="Home">Home</option>
                <option value="Books">Books</option>

            </select>
        </div>

        <div class="form-group">
            <label>Price</label>
            <input @bind="editingProduct.Price"
                   class="form-control"
                   type="number"
                   step="0.01" />
        </div>

        <div class="form-group">
            <label>Quantity</label>
            <input @bind="editingProduct.Quantity"
                   class="form-control"
                   type="number" />
        </div>

        <div class="form-group">
            <label>Minimum Stock Level</label>
            <input @bind="editingProduct.MinimumStockLevel"
                   class="form-control"
                   type="number" />
        </div>

        <div class="form-group">
            <label>
                <input @bind="editingProduct.IsActive"
                       class="form-check-input"
                       type="checkbox" />
                Is Active?
            </label>
        </div>

        <button type="button"
                class="btn btn-success"
                @onclick="SaveProduct"
                disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span>Saving...</span>
            }
            else
            {
                <span>Save Changes</span>
            }
        </button>

    </form>
}


<style>
    .wrapper {	
	max-width: 600px;
	margin: 0 auto;
    display:flex;
    flex-direction: column;
    gap: 20px;
}
</style>

@code {

    [Parameter]
    public int Id { get; set; }

    private Product? editingProduct;
    private string validationError = string.Empty;
    private string successMessage = string.Empty;
    private bool isLoading = true;
    private bool isSubmitting = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            editingProduct = await Http.GetFromJsonAsync<Product>($"api/product/{Id}");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error loading product: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProduct()
    {
        validationError = string.Empty;
        successMessage = string.Empty;

        var errors = new List<string>();

        if (string.IsNullOrWhiteSpace(editingProduct?.Name))
            errors.Add("Name is required.");

        if (string.IsNullOrWhiteSpace(editingProduct?.CodeSKU))
            errors.Add("SKU is required.");

        if (string.IsNullOrWhiteSpace(editingProduct?.Description))
            errors.Add("Description is required.");

        if (string.IsNullOrWhiteSpace(editingProduct?.Category))
            errors.Add("Category is required.");

        if (editingProduct?.Price <= 0)
            errors.Add("Price must be greater than 0.");

        if (editingProduct?.Quantity < 0)
            errors.Add("Quantity cannot be negative.");

        if (editingProduct?.MinimumStockLevel < 0)
            errors.Add("Minimum stock level cannot be negative.");

        if (errors.Count > 0)
        {
            validationError = string.Join(" ", errors);
            return;
        }

        isSubmitting = true;

        try
        {
            var response = await Http.PutAsJsonAsync($"api/product/{editingProduct!.Id}", editingProduct);

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/read");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                validationError = $"Server error: {response.StatusCode} — {errorContent}";
            }
        }
        catch (HttpRequestException httpEx)
        {
            validationError = $"Network error: {httpEx.Message}";
        }
        catch (Exception ex)
        {
            validationError = $"Request failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}