@page "/create"
@attribute [Authorize(Policy = "product:manage")]
@inject HttpClient Http


<PageTitle>Create</PageTitle>

<h1>Create a Product!</h1>
<p role="status">Create a new product by filling out the form below.</p>

<div>
    @if (!string.IsNullOrEmpty(validationError))
    {
        <div class="alert alert-danger" role="alert">@validationError</div>
    }
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success" role="alert">@successMessage</div>
    }
    <form class="wrapper">
        <div class="form-group">
            <label>Name</label>
            <input @bind="newProduct.Name" class="form-control" type="text" required="" autofocus="" placeholder="Enter product name..." />
        </div>

        <div class="form-group">
            <label>SKU Code</label>
            <input @bind="newProduct.CodeSKU" class="form-control" type="text" required="" placeholder="Enter SKU..." />
        </div>

        <div class="form-group">
            <label>Description</label>
            <textarea @bind="newProduct.Description" class="form-control" type="text" required="" placeholder="Enter description..." />
        </div>

        <div class="form-group">
            <label>Category</label>
            <select @bind="newProduct.Category" class="form-control" required="">
                <option value="">Select category...</option>
                <option value="Electronics">Electronics</option>
                <option value="Clothing">Clothing</option>
                <option value="Home">Home</option>
                <option value="Books">Books</option>
            </select>
        </div>

        <div class="form-group">
            <label>Price</label>
            <input @bind="newProduct.Price" class="form-control" type="number" step="0.01" required="" placeholder="Enter price..." />
        </div>

        <div class="form-group">
            <label>Quantity</label>
            <input @bind="newProduct.Quantity" class="form-control" type="number" min="0" required="" placeholder="Enter quantity..." />
        </div>

        <div class="form-group">
            <label>Minimum Stock Level</label>
            <input @bind="newProduct.MinimumStockLevel" class="form-control" type="number" min="0" required="" placeholder="Enter minimum stock level..." />
        </div>

        <div class="form-group">
            <label>
                <input @bind="newProduct.IsActive" class="form-check-input" type="checkbox" />
                Is Active?
            </label>
        </div>

        <button type="button" class="btn btn-primary btn-block" @onclick="CreateProduct" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span>Creating...</span>
            }
            else
            {
                <span>Create Product!</span>
            }
        </button>
        
    </form>
</div>

<style>
    .wrapper {	
	max-width: 600px;
	margin: 0 auto;
    display:flex;
    flex-direction: column;
    gap: 20px;
}
</style>

@code {

    private Product newProduct = new();
    private string validationError = string.Empty;
    private string successMessage = string.Empty;
    private bool isSubmitting = false;

    private async Task CreateProduct()
    {
        validationError = string.Empty;
        successMessage = string.Empty;
        var errors = new List<string>();

        if (string.IsNullOrWhiteSpace(newProduct.Name))
            errors.Add("Name is required.");

        if (string.IsNullOrWhiteSpace(newProduct.CodeSKU))
            errors.Add("SKU is required.");

        if (string.IsNullOrWhiteSpace(newProduct.Description))
            errors.Add("Description is required.");

        if (string.IsNullOrWhiteSpace(newProduct.Category))
            errors.Add("Category is required.");

        if (newProduct.Price <= 0)
            errors.Add("Price must be greater than 0.");

        if (newProduct.Quantity < 0)
            errors.Add("Quantity cannot be negative.");

        if (newProduct.MinimumStockLevel < 0)
            errors.Add("Minimum stock level cannot be negative.");

        if (errors.Count > 0)
        {
            validationError = string.Join(" ", errors);
            return; 
        }

        isSubmitting = true;

        // this is for quick testing
        @* Product productToCreate = new Product
        {
            Name = "test",
            CodeSKU = "TEST-001",
            Description = "probando",
            Category = "Testing",
            Price = 10,
            Quantity = 50,
            MinimumStockLevel = 2,
            IsActive = true
        };
        
        newProduct = productToCreate; *@

        try
        {
            // Serialize the Product to JSON 
            var response = await Http.PostAsJsonAsync("api/product", newProduct);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<CreateProductResponse>();
                successMessage = $"{result?.Message} (ID: {result?.ProductId})";
                newProduct = new Product(); // Reset form
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                validationError = $"Server error: {response.StatusCode} — {errorContent}";
            }
        }
        catch (HttpRequestException httpEx)
        {
            validationError = $"Network error: {httpEx.Message}";
        }
        catch (NotSupportedException nsEx)
        {
            validationError = $"Content type error: {nsEx.Message}";
        }
        catch (System.Text.Json.JsonException jsonEx)
        {
            validationError = $"JSON error: {jsonEx.Message}";
        }
        catch (Exception ex)
        {
            validationError = $"Request failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class CreateProductResponse
    {
        public string? Message { get; set; }
        public int ProductId { get; set; }
        public string? ProductName { get; set; }
    }
}
